# ===========================================================================
#  open-lab-reservation-system-test-suite — 根目录忽略规则
#  说明:被测系统位于 system-under-test/,其前端 RuoYi-Vue3 另有自带 .gitignore。
#       本文件为仓库级兜底规则,覆盖 Java/Maven、Node、IDE、操作系统产物。
# ===========================================================================

# ----- Java / 编译产物 -----
*.class
*.ctxt
.mtj.tmp/

# ----- 日志 -----
*.log
logs/

# ----- 打包产物 -----
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# ----- JVM 崩溃日志 -----
hs_err_pid*
replay_pid*

# ----- Maven -----
target/
.mvn/timing.properties
# Maven Wrapper 文件需入库(mvnw / mvnw.cmd / .mvn/wrapper/maven-wrapper.properties)，
# 仅忽略 wrapper 下载缓存的发行版与本地 jar
.mvn/wrapper/maven-wrapper.jar
.mvn/wrapper/dists/

# ----- Node / 前端构建 -----
node_modules/
dist/
dist-ssr/
.npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.eslintcache

# ----- IDE / 编辑器 -----
.idea/
*.iml
*.ipr
*.iws
.vscode/
*.sw?
*.suo
*.ntvs*
*.njsproj
*.sln
*.local

# ----- 操作系统 -----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ----- 环境变量(可能含口令/密钥,不入库;仅提交 .env.example 模板) -----
.env
.env.local
.env.*.local
!.env.example
