# ============================================================================
# Docker Compose 环境变量模板
# 用法：复制为同目录下的 .env 后按需修改  ——  cp .env.example .env
# 改动后重新执行：docker compose up -d
# ⚠️ 以下为本地演示默认值；对外部署前务必修改口令，且 .env 不会被提交到仓库。
# ============================================================================

# 数据库
MYSQL_DATABASE=open_lab_reservation
MYSQL_PASSWORD=root

# 宿主机端口映射（避开本机已占用的 3306/6379）
MYSQL_HOST_PORT=3307
REDIS_HOST_PORT=6380
BACKEND_HOST_PORT=8080
FRONTEND_HOST_PORT=81
